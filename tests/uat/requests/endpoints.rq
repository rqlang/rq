let base = "http://localhost:8080";
let default_headers = [
    "X-Uat": "endpoint",
];

let user_id = "123";

ep api(url: base, headers: default_headers, qs: "v=1");

  /* This is a comment
     that spans multiple
     lines */

ep users<api>("/users") {
    rq list();
    rq get(user_id);
    [method(POST)]
    [required(user_name)]
    [required(user_role)]
    rq create(body: ${"name": "{{user_name}}", "role": "{{user_role}}"});
}
